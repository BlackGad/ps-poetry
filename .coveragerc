[run]
branch = True
source =
    src/
omit =
    tests/*
    experiments/*
    */__init__.py
    conftest.py
    launcher.py

[report]
show_missing = True
omit =
    tests/*
    */__init__.py
    */test_*.py
    */exp_*.py
    experiments/*
    conftest.py
    launcher.py

[html]
directory = coverage_html

[xml]
output = coverage.xml